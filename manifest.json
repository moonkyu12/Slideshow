{
  "manifest_version": 3,
  "name": "Classroom Slideshow",
  "description": "Google Classroom에서 PPT/PDF 파일을 우클릭하여 슬라이드쇼로 발표하세요",
  "version": "1.0.0",
  "permissions": [
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "*://classroom.google.com/*",
    "*://drive.google.com/*",
    "*://docs.google.com/*",
    "*://drive.usercontent.google.com/*",
    "*://*.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://classroom.google.com/*",
        "*://drive.google.com/*",
        "*://docs.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer/viewer.html", "viewer/viewer.css", "viewer/viewer.js", "viewer/lib/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
